<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state with green border -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/inventory_item_background" /> <!-- Background color -->
            <stroke android:width="6dp" android:color="@color/inventory_item_border"/> <!-- Green border -->
            <corners android:radius="4dp"/> <!-- Optional rounded corners -->
        </shape>
    </item>
    <!-- Default state (no border) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/inventory_item_background" /> <!-- Default background color -->
            <stroke android:width="6dp" android:color="@color/inventory_item_background"/> <!-- No border or same as background -->
            <corners android:radius="4dp"/> <!-- Optional rounded corners -->
        </shape>
    </item>
</selector>