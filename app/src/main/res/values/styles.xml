<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Define your custom menu item text appearance -->
    <style name="CustomMenuTextStyle" parent="TextAppearance.AppCompat.Widget.ActionBar.Menu">
        <item name="android:textColor">@color/menu_item_text</item>
        <item name="android:textSize">@dimen/menu_text</item>
    </style>


    <style name="GeneralButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/button_text_color</item>
        <item name="android:textSize">@dimen/small_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="GeneralTextField" parent="Widget.AppCompat.TextView">
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">@color/text_background</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/text</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="GeneralEditTextField" parent="Widget.AppCompat.EditText">
        <item name="android:minHeight">48dp</item>
        <item name="android:textColorHint">#D0020202</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">@color/edit_text_background</item>
        <item name="android:textColor">@color/edit_text_color</item>
        <item name="android:textSize">@dimen/text</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>




    <style name="SaveSlotContainer">
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/activity_element_spacing2</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_weight">1</item>
    </style>





    <!-- LinearLayout for Save Slot -->









    <!-- UPDATED AND IN USE -->
    <!-- TOP BAR -->
    <style name="BackButtonStyle">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/back_icon</item>
        <item name="android:backgroundTint">@color/back_button</item>
    </style>
    <style name="GeneralTitle" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:textSize">@dimen/title_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/title_color</item>
    </style>

    <style name="DeleteButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:padding">8dp</item>
        <item name="android:src">@android:drawable/ic_menu_delete</item>
    </style>

</resources>